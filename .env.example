# =============================================
# 环境配置模板文件
# 使用方法：复制此文件为 .env，并修改对应的值
# =============================================

# ---------------------------------------------
# Spring Profile 环境选择
# 可选值: dev, test, prod
# ---------------------------------------------
SPRING_PROFILES_ACTIVE=dev

# ---------------------------------------------
# 数据库配置
# ---------------------------------------------
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=permission_system
SPRING_DATASOURCE_URL=jdbc:mysql://db:3306/permission_system?useUnicode=true&characterEncoding=UTF-8&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true&useSSL=false
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=root

# ---------------------------------------------
# JWT 配置
# JWT_SECRET 必须至少32个字符，生产环境请使用强随机密钥
# ---------------------------------------------
JWT_SECRET=ChangeMe_GenerateA32+CharSecureRandomString!
JWT_EXPIRATION=86400000

# ---------------------------------------------
# CORS 跨域配置
# 多个域名用逗号分隔
# ---------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ---------------------------------------------
# 日志配置
# ---------------------------------------------
LOG_FILE_PATH=/app/logs/app.log

# ---------------------------------------------
# 应用版本（部署脚本使用）
# ---------------------------------------------
APP_VERSION=1.0.0

# ---------------------------------------------
# 时区配置
# ---------------------------------------------
TZ=Asia/Shanghai
